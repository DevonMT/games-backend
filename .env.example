# ---- Steam ----
# Get a key at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Your 64-bit SteamID (the long numeric ID, e.g. 76561197960287930).
# Find it at https://steamid.io/ by pasting your profile URL.
STEAM_USER_ID=

# ---- RAWG ----
# Free API key from https://rawg.io/apidocs (sign up, then "API key").
# Powers the GET /releases endpoint (recent & upcoming releases).
RAWG_API_KEY=

# ---- Database (SQLite via better-sqlite3) ----
# Where the games_table SQLite file lives. Defaults to ./data/games.db locally.
# On Vercel the filesystem is read-only except /tmp, so set this to
# /tmp/games.db there (it behaves as a warm-instance cache, not durable storage).
DATABASE_PATH=./data/games.db

# ---- Claude (Task 3) ----
CLAUDE_API_KEY=

# ---- Auth (Task 1) ----
# Shared secret the frontend must send in the `x-api-secret` header.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SHARED_API_SECRET=

# ---- Server ----
PORT=8787
# Comma-separated list of allowed CORS origins for the dashboard.
ALLOWED_ORIGINS=http://localhost:4321,https://devontroedel.com
